<Window x:Class="KnowledgeBase.WpfApp.InfoDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Information" Height="400" Width="600"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderText" Grid.Row="0" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <TextBox x:Name="ContentText" Grid.Row="1" TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 IsReadOnly="True" Padding="6"/>

        <StackPanel x:Name="UrlPanel" Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0" Visibility="Collapsed">
            <Button x:Name="OpenLinkButton" Content="Link im Browser öffnen" Click="OpenLinkButton_OnClick" Padding="12,6"/>
        </StackPanel>
    </Grid>
</Window>
